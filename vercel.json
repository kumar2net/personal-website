{
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "apps/personal-website/dist",
  "build": {
    "env": {
      "ROLLUP_SKIP_NODEJS_NATIVE_BUILD": "1"
    }
  },
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/media/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/generate/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/data/keydata-latest.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, s-maxage=86400, stale-while-revalidate=43200"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "news.kumar2net.com" }],
      "destination": "/news/index.html"
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "news.kumar2net.com" }],
      "destination": "/news/$1"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
