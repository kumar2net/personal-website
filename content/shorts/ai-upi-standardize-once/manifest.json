    "captions": [
      { "id": "c1_en", "lang": "en", "text": "Wait, UPI can do this?" },
      { "id": "c2_en", "lang": "en", "text": "Build one vertical template, not ten timelines." },
      { "id": "c3_en", "lang": "en", "text": "Lock 1080 by 1920 once and keep the safe zones fixed." },
      { "id": "c4_en", "lang": "en", "text": "Hooks, lower-thirds, stickers, and CTA stay swappable." },
      { "id": "c5_en", "lang": "en", "text": "That means faster edits and fewer layout mistakes." },
      { "id": "c6_en", "lang": "en", "text": "Write one English master script with tight caption timing." },
      { "id": "c7_en", "lang": "en", "text": "Translate the SRT, not the whole edit, into Tamil and Hindi." },
      { "id": "c8_en", "lang": "en", "text": "Generate matching TTS for each language at 48 kHz." },
      { "id": "c9_en", "lang": "en", "text": "Then render three localized MP4s from the same picture-lock." },
      { "id": "c10_en", "lang": "en", "text": "The payoff is simple: standardize once and scale daily." },
      { "id": "c11_en", "lang": "en", "text": "Tamil, English, and Hindi all ship from one job." },
      { "id": "c12_en", "lang": "en", "text": "More at kumar2net.com. Playlist: Wireless Explained." },
      { "id": "c1_ta", "lang": "ta", "text": "ஒரு நிமிடம், UPI இதையும் செய்யுமா?" },
      { "id": "c2_ta", "lang": "ta", "text": "பத்து timelines வேண்டாம், ஒரு vertical template போதும்." },
      { "id": "c3_ta", "lang": "ta", "text": "1080 x 1920 layout-ஐ ஒருமுறை fix செய்து safe zone-ஐ பூட்டுங்கள்." },
      { "id": "c4_ta", "lang": "ta", "text": "Hook, lower-third, stickers, CTA மட்டும் மாற்றினால் போதும்." },
      { "id": "c5_ta", "lang": "ta", "text": "அதனால் edit வேகம் கூடும், layout தவறுகள் குறையும்." },
      { "id": "c6_ta", "lang": "ta", "text": "முதலில் tight timing உடன் English master SRT எழுதுங்கள்." },
      { "id": "c7_ta", "lang": "ta", "text": "பிறகு edit-ஐ அல்ல, SRT-ஐ Tamil, Hindi-க்கு மாற்றுங்கள்." },
      { "id": "c8_ta", "lang": "ta", "text": "ஒவ்வொரு மொழிக்கும் pace match ஆகும் TTS audio உருவாக்குங்கள்." },
      { "id": "c9_ta", "lang": "ta", "text": "அதே picture-lock-ல் இருந்து மூன்று localized MP4-கள் render ஆகட்டும்." },
      { "id": "c10_ta", "lang": "ta", "text": "முக்கிய பலன்: ஒருமுறை standardize செய்தால் தினமும் scale செய்யலாம்." },
      { "id": "c11_ta", "lang": "ta", "text": "Tamil, English, Hindi எல்லாமே ஒரே job-ல் ship ஆகும்." },
      { "id": "c12_ta", "lang": "ta", "text": "மேலும் kumar2net.com. Playlist: Wireless Explained." },
      { "id": "c1_hi", "lang": "hi", "text": "रुको, UPI यह भी कर सकता है?" },
      { "id": "c2_hi", "lang": "hi", "text": "दस timelines मत बनाओ, एक vertical template बनाओ." },
      { "id": "c3_hi", "lang": "hi", "text": "1080 x 1920 layout को एक बार lock करो और safe zones तय रखो." },
      { "id": "c4_hi", "lang": "hi", "text": "Hook, lower-third, stickers और CTA बस swap होने चाहिए." },
      { "id": "c5_hi", "lang": "hi", "text": "इससे edit तेज होगा और layout गलतियां कम होंगी." },
      { "id": "c6_hi", "lang": "hi", "text": "पहले tight timing वाला English master SRT बनाओ." },
      { "id": "c7_hi", "lang": "hi", "text": "फिर पूरे edit को नहीं, SRT को Tamil और Hindi में बदलो." },
      { "id": "c8_hi", "lang": "hi", "text": "हर भाषा के लिए pace-matched TTS audio बनाओ." },
      { "id": "c9_hi", "lang": "hi", "text": "उसी picture-lock से तीन localized MP4 render करो." },
      { "id": "c10_hi", "lang": "hi", "text": "फायदा साफ है: एक बार standardize करो, रोज scale करो." },
      { "id": "c11_hi", "lang": "hi", "text": "Tamil, English और Hindi एक ही job से निकलते हैं." },
      { "id": "c12_hi", "lang": "hi", "text": "और देखने के लिए kumar2net.com. Playlist: Wireless Explained." }
    ]
  },
