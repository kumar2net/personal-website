{
  "headers": [
    {
      "source": "/data/heatmap-latest.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, s-maxage=86400, stale-while-revalidate=43200"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/news",
      "destination": "/news/index.html"
    },
    {
      "source": "/news/:path*",
      "destination": "/news/:path*"
    }
  ]
}
